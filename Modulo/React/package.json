{
  "name": "modulo-swap-react",
  "description": "Modulo DeFi prototype — built with BakedUX",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "deploy": "vite build && cd ../Prototype/vercel && vercel --prod --yes",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "husky",
    "qa:css": "grep -rn ':[[:space:]]*[0-9][a-z][a-z][a-z]px\\|intset\\|--bk-im\\b' src/ || echo 'CSS QA: clean'",
    "test:visual": "playwright test --config playwright.config.cjs",
    "test:visual:update": "playwright test --config playwright.config.cjs --update-snapshots"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "npx vitest run --reporter=verbose 2>&1 | tail -20"
    ],
    "src/**/*.css": [
      "echo 'CSS files staged — check for hardcoded values'"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "bignumber.js": "^10.0.2",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-aria-components": "^1.4.0",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^4.1.2",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
